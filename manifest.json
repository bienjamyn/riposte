{
  "manifest_version": 3,
  "name": "Riposte",
  "description": "Track your reply game on X. Analytics, streaks, and AI-powered reply suggestions.",
  "version": "0.1.3",
  "icons": {
    "16": "public/icons/icon16.png",
    "32": "public/icons/icon32.png",
    "48": "public/icons/icon48.png",
    "128": "public/icons/icon128.png"
  },
  "permissions": ["storage", "tabs", "activeTab"],
  "host_permissions": ["*://x.com/*"],
  "background": {
    "service_worker": "src/background/service-worker.ts",
    "type": "module"
  },
  "content_scripts": [
    {
      "matches": ["*://x.com/*"],
      "js": ["src/content/page-intercept.ts"],
      "run_at": "document_start",
      "world": "MAIN"
    },
    {
      "matches": ["*://x.com/*"],
      "js": ["src/content/observer.ts"],
      "run_at": "document_start"
    }
  ],
  "action": {
    "default_title": "Riposte",
    "default_popup": "src/popup/popup.html",
    "default_icon": {
      "16": "public/icons/icon16-grey.png",
      "32": "public/icons/icon32-grey.png",
      "48": "public/icons/icon48-grey.png"
    }
  },
  "web_accessible_resources": [{
    "resources": ["src/sidebar/index.html", "public/icons/icon128.png", "public/icons/riposte-logo.png"],
    "matches": ["*://x.com/*"]
  }]
}
